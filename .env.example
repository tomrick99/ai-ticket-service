# Spring profiles
SPRING_PROFILES_ACTIVE=prod

# MySQL container
MYSQL_DATABASE=ai_ticket_service
MYSQL_USER=ticket_user
MYSQL_PASSWORD=change_me_ticket_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# App datasource
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/ai_ticket_service?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=ticket_user
SPRING_DATASOURCE_PASSWORD=change_me_ticket_password

# Qwen provider
DASHSCOPE_API_KEY=replace_with_real_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
APP_AI_PROVIDER=qwen
APP_AI_FALLBACK=none
APP_SECURITY_ENABLED=true
APP_SECURITY_API_KEY=replace_with_app_api_key
APP_SECURITY_HEADER_NAME=X-API-Key
APP_SECURITY_CLIENT_ID_HEADER=X-Client-Id
APP_AUDIT_ENABLED=true

# Optional tuning
JAVA_OPTS=
SPRING_DATASOURCE_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_MINIMUM_IDLE=5
SPRING_DATASOURCE_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_MAX_LIFETIME=1800000
SPRING_DATASOURCE_VALIDATION_TIMEOUT=5000
SPRING_DATASOURCE_KEEPALIVE_TIME=300000
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_AUDIT=INFO
